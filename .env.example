# ─────────────────────────────────────────────────────────────
# DNA-Landscaping — Environment Variables
# Copy this file to .env (local) or set these in your Vercel
# project: Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# REQUIRED ───────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma / the pg driver.
# Use a hosted Postgres (Neon, Supabase, Vercel Postgres, etc.).
# Must include sslmode=require for most hosted providers.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Secret used by NextAuth to sign/encrypt JWT session tokens.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of the deployed app. On Vercel set this to your
# production domain (NextAuth uses it for callbacks & email links).
# Local: http://localhost:3000
NEXTAUTH_URL=

# OPTIONAL ───────────────────────────────────────────────────

# Resend API key for sending invoice emails. If unset, the app
# falls back to a non-functional test key ("re_test").
RESEND_API_KEY=

# Fallback user id assigned to estimates when none is supplied.
# Defaults to "default-user-id" if unset.
DEFAULT_USER_ID=

# Square payment integration (production path is a placeholder /
# not yet wired up — safe to leave blank). Sandbox payments work
# without these.
NEXT_PUBLIC_SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
